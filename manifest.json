{
  "manifest_version": 3,
  "name": "TikTok Chat Typing Fixer",
  "version": "1.0.0",
  "description": "Fixes Vietnamese IME typing glitches and message sending char drop bugs on TikTok Web chat.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.tiktok.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://www.tiktok.com/*"]
    }
  ]
}

